{
  "name": "@swell-enterprise/container",
  "version": "0.0.7",
  "description": "A simple DI container for TypeScript projects.",
  "author": "Keith Mifsud <mifsud.k@gmail.com> (https://keith-mifsud.me)",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "engines": {
    "node": ">=22"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/keithmifsud/swell-container.git"
  },
  "bugs": {
    "url": "https://github.com/keithmifsud/swell-container/issues"
  },
  "homepage": "https://keith-mifsud.me/collaborate/",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist/**",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm,cjs --dts",
    "dev": "tsdown src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "package": "pnpm pack",
    "prepublishOnly": "pnpm run build && publint && attw --pack"
  },
  "keywords": [
    "dependency-injection",
    "di",
    "ioc",
    "container",
    "typescript"
  ],
  "packageManager": "pnpm@11.12.0",
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "publint": "^0.3.21",
    "tsdown": "^0.22.13",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
