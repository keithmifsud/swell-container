{
  "name": "@swell/container",
  "version": "0.0.1",
  "description": "A simple DI container for TypeScript projects.",
  "author": "Keith Mifsud <mifsud.k@gmail.com> (https://keith-mifsud.me)",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist/**",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown src/SwellContainer.ts --format esm,cjs --dts",
    "dev": "tsdown src/SwellContainer.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "package": "pnpm pack",
    "prepublishOnly": "pnpm run build && publint && attw --pack",
    "publish": "pnpm publish --access public"
  },
  "keywords": [
    "dependency-injection",
    "di",
    "ioc",
    "container",
    "typescript"
  ],
  "packageManager": "pnpm@11.12.0",
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "publint": "^0.3.21",
    "tsdown": "^0.22.13",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
